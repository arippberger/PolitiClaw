{
  "name": "politiclaw",
  "version": "0.0.1",
  "description": "Local-first OpenClaw plugin: a personal political co-pilot for legislation, reps, elections, and action.",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": "./src/index.ts"
  },
  "scripts": {
