{
  "name": "@politiclaw/politiclaw",
  "version": "0.0.7",
  "description": "Local-first OpenClaw plugin: a civic copilot that holds your representatives accountable to the values you declare — watches federal legislation and elections for you, flags when your reps' actions align or don't, and drafts letters you send yourself.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/__fixtures__/**",
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/__fixtures__/**",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": "./dist/index.js",
    "compat": {
      "pluginApi": ">=2026.4.21",
      "minGatewayVersion": "2026.4.21"
    },
    "build": {
      "openclawVersion": "2026.4.21",
      "pluginSdkVersion": "2026.4.21"
    },
    "install": {
      "minHostVersion": ">=2026.4.21"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/index.ts",
    "docs:generate": "tsx ./scripts/docs.mts generate",
    "docs:check": "tsx ./scripts/docs.mts check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --config ../../eslint.config.js .",
    "pretest": "npm run docs:check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.15"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "shapefile": "^0.6.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
